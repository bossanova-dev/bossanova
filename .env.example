CODESIGN_IDENTITY=bossanova.dev

# ─── Terraform Cloud ───────────────────────────────────────────────
# Set as workspace variables in app.terraform.io (org: bossanova)
# Workspaces: bossanova-staging, bossanova-production

# Terraform variable: "staging" or "production" (per workspace)
TF_VAR_environment=

# Terraform variables (shared across workspaces)
TF_VAR_cloudflare_account_id=
TF_VAR_cloudflare_zone_id=
TF_VAR_cloudflare_api_token=        # sensitive — Zone:DNS:Edit, Account:Pages:Edit, Account:R2:Edit

# ─── GitHub Actions Secrets ────────────────────────────────────────
# Set at github.com/recurser/bossanova → Settings → Secrets

TF_API_TOKEN=                        # TF Cloud team/user API token
FLY_API_TOKEN=                       # same as above, used by flyctl deploy
CLOUDFLARE_API_TOKEN=                # used by wrangler pages deploy

# ─── GitHub Actions Variables (non-secret) ─────────────────────────
# Set at github.com/recurser/bossanova → Settings → Variables

VITE_WORKOS_CLIENT_ID=client_01KP805YA85J1BJ4FZN39R7MRT

# ─── Fly.io Secrets (per app, via flyctl secrets set) ──────────────
# Run once per app: flyctl secrets set -a bosso-staging ...
#                   flyctl secrets set -a bosso-production ...

BOSSO_ADDR=                          # defaults to :8080; local dev should use :8181 to avoid nginx clashes
BOSSO_WORKOS_CLIENT_ID=client_01KP805YA85J1BJ4FZN39R7MRT
BOSSO_CORS_ORIGINS=                  # https://app.bossanova.dev or https://app-staging.bossanova.dev
LITESTREAM_BUCKET=                   # bosso-litestream-production or bosso-litestream-staging
LITESTREAM_ENDPOINT=                 # https://<account_id>.r2.cloudflarestorage.com
LITESTREAM_ACCESS_KEY_ID=            # R2 API token
LITESTREAM_SECRET_ACCESS_KEY=        # R2 API token secret

# Bug-report (ctrl+b) Resend delivery
BOSSO_RESEND_API_KEY=                # Resend API key; when unset, reports persist but no email is sent
BOSSO_RESEND_FROM=                   # verified sender; defaults to reports@bossanova.dev
BOSSO_BUG_REPORT_EMAIL=              # triage inbox; defaults to dave@recurser.com

# ─── TUI / daemon client-side overrides (optional) ─────────────────
# Unset → production defaults baked into the binaries. Override for
# staging/self-host. BOSSD_ORCHESTRATOR_URL="" forces local-only mode.

BOSS_WORKOS_CLIENT_ID=               # defaults to production client_01KP805YXXAMZSN2YB4NGXS9XB
BOSS_REPORT_URL=                     # defaults to https://orchestrator.bossanova.dev
BOSSD_ORCHESTRATOR_URL=              # defaults to https://orchestrator.bossanova.dev; empty = local-only

# Local-dev escape hatch on macOS: setting this to "file" routes auth tokens
# to the encrypted file backend at ~/.config/bossanova/keyring/ instead of
# the system Keychain, so iterating with `go run` doesn't trigger a Keychain
# password prompt on every rebuild. Leave unset in production.
BOSS_KEYRING_BACKEND=file
