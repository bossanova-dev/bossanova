{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": false
  },
  "files": {
    "ignore": ["node_modules", "dist", "*.json"]
  }
}
